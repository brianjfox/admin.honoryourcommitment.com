# Admin backend configuration. Copy to `.env`.

NODE_ENV=development
HOST=127.0.0.1
PORT=4000

# Same Postgres as the API. The admin connects read-mostly to the public.*
# campaign tables and owns the `admin` schema. Reuse the API's DATABASE_URL.
DATABASE_URL=postgres://phyc:phyc@localhost:5432/phyc

# Secret for signing the session JWT (stored in an httpOnly cookie).
# Generate: openssl rand -hex 32
JWT_SECRET=dev-insecure-change-me

# Cookie: secure cookies require HTTPS. Set true in production (served over TLS).
COOKIE_SECURE=false

# First SUPER_ADMIN — seeded on first boot if the users table is empty.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Public origin of the admin site (used to build password-reset links).
ADMIN_PUBLIC_URL=http://localhost:5180

# SMTP for password-reset emails — reuse the API's transactional provider.
# Leave DISABLE_EMAIL=true to log the reset link instead of sending.
DISABLE_EMAIL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Honor Your Commitment <no-reply@honoryourcommitment.com>"
EMAIL_REPLY_TO=

# --- Campaign-update broadcasts ---
# Public origin of the API — unsubscribe links in broadcasts point here.
API_PUBLIC_URL=http://localhost:3000
# Must equal the API's UNSUBSCRIBE_SECRET so the links verify. If both are left
# blank, each service derives the same value from the shared DATABASE_URL.
UNSUBSCRIBE_SECRET=
# Delay (ms) between broadcast messages, to respect provider rate limits.
BROADCAST_DELAY_MS=200
